import { Theme } from "theme.slint";
import { AppState, FileEntry } from "globals.slint";
import { FileIcon } from "file_icon.slint";
import { InputOverlay } from "input_overlay.slint";
import { ListView } from "std-widgets.slint";

// "此电脑"专属平铺视图：图标在左，名称/类型/容量条在右，多列自适应。
// 与 Windows 资源管理器「平铺」一致；仅在浏览 this-pc:// 时使用，其它目录走网格/列表。
// 复用 ListView 按行虚拟化 + InputOverlay 统一处理选中/双击/框选。
export component ThisPcView inherits Rectangle {
    callback request-context-menu(int, length, length);
    border-radius: 12px;
    border-width: 1px;
    border-color: Theme.border;
    background: Theme.surface.with-alpha(Theme.panel-alpha);
    clip: true;

    // 平铺卡片尺寸随图标缩放（Ctrl+滚轮）
    // tile-h 增至 82px：确保名称(13px行高) + 容量条(5px) + 副标题(11px行高) + 间距
    // 在 10px*2 padding 内完整显示，不再纵向截断
    property <length> tile-w: 248px * AppState.icon-scale;
    // 名称(18px)+间距(4px)+容量条(5px)+间距(4px)+副标题(15px)+上下padding(20px) = 66px 为文字内容所需的最小高度，
    // 与固定字号一同不随 icon-scale 缩小，避免小缩放时卡片高度不够而被裁切（见下方 Text 的固定 height）
    property <length> tile-h: max(82px * AppState.icon-scale, 74px);
    property <length> icon-box: 44px * AppState.icon-scale;
    property <length> gap: 12px;
    property <length> pitch-x: root.tile-w + root.gap;
    property <length> row-h: root.tile-h + root.gap;
    property <int> cols: max(1, floor((list.visible-width - 24px) / root.pitch-x));
    property <int> rows: ceil(AppState.entries.length / max(1, root.cols));

    list := ListView {
        width: 100%;
        height: 100%;
        for r in root.rows: Rectangle {
            height: root.row-h;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: r == 0 ? 12px : 0px;
                spacing: root.gap;
                alignment: start;

                for col in root.cols: tile := Rectangle {
                    property <int> idx: r * root.cols + col;
                    property <bool> valid: self.idx < AppState.entries.length;
                    width: root.tile-w;
                    height: root.tile-h;

                    if tile.valid: card := Rectangle {
                        property <FileEntry> entry: AppState.entries[tile.idx];
                        border-radius: Theme.radius-card;
                        border-width: 1px;
                        border-color: card.entry.selected ? #0078d473 : #0000000f;
                        // card-alpha：半透明模式下给微弱填充避免实心白板压毛玻璃，不透明时为 1.0
                        background: card.entry.selected
                            ? #0078d426
                            : (ov.hover-idx == tile.idx ? #0078d40a
                                : Theme.surface.with-alpha(Theme.card-alpha));
                        clip: true;

                        HorizontalLayout {
                            padding: 10px;
                            spacing: 10px;
                            alignment: start;

                            // 左：图标（系统图标模式回填后显示真实盘符/缩略图）
                            VerticalLayout {
                                alignment: center;
                                FileIcon {
                                    icon-class: card.entry.icon-class;
                                    label: card.entry.icon-label;
                                    thumb: card.entry.thumb;
                                    has-thumb: card.entry.has-thumb;
                                    box: root.icon-box;
                                }
                            }

                            // 右：名称 / 容量条 / 副标题
                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: card.entry.name;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    color: Theme.text;
                                    overflow: elide;
                                    height: 18px;
                                }
                                // 驱动器容量条（disk-ratio>0 时显示）
                                if card.entry.disk-ratio > 0: Rectangle {
                                    height: 5px;
                                    border-radius: 2.5px;
                                    background: #dce6f0;
                                    clip: true;
                                    Rectangle {
                                        x: 0;
                                        width: parent.width * card.entry.disk-ratio;
                                        height: parent.height;
                                        border-radius: 2.5px;
                                        background: card.entry.disk-color;
                                    }
                                }
                                Text {
                                    // 驱动器显示容量副标题；其它（如便携设备）显示类型
                                    text: card.entry.disk-ratio > 0 ? card.entry.disk-info : card.entry.kind;
                                    font-size: Theme.fs-tiny;
                                    color: Theme.subtle;
                                    overflow: elide;
                                    height: 15px;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // 统一输入层：平铺即二维网格，复用 grid 命中逻辑
    ov := InputOverlay {
        width: 100%;
        height: 100%;
        pane: "left";
        mode: "grid";
        count: AppState.entries.length;
        cols: root.cols;
        row-h: root.row-h;
        cell-w: root.tile-w;
        pitch-x: root.pitch-x;
        top-pad: 12px;
        left-pad: 12px;
        vp-y <=> list.viewport-y;
        vp-h: list.viewport-height;
        vis-h: list.visible-height;
        request-context-menu(i, mx, my) => { root.request-context-menu(i, mx, my); }
    }
}
