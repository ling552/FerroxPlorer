import { Theme } from "theme.slint";
import { AppState } from "globals.slint";
import { FileIcon } from "file_icon.slint";
import { ScrollView, LineEdit } from "std-widgets.slint";

// 通用小按钮（计算 / 复制 / 校验）
component MiniBtn inherits Rectangle {
    in property <string> label;
    in property <bool> enabled-look: true;
    callback clicked;
    width: 56px;
    border-radius: Theme.radius-btn;
    border-width: 1px;
    border-color: Theme.border;
    background: !root.enabled-look ? #f6f8fa : (touch.has-hover ? #f0f5fa : Theme.surface);
    Text {
        text: root.label;
        font-size: Theme.fs-small;
        color: root.enabled-look ? #284057 : Theme.muted;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component tab-btn inherits Rectangle {
    in property <string> label;
    in property <int> idx;
    in property <int> active-tab;
    callback selected(int);
    height: 34px;
    border-radius: 8px;
    background: active-tab == idx ? Theme.primary-soft : transparent;
    HorizontalLayout {
        padding-left: 12px; padding-right: 12px;
        Text {
            text: label;
            font-size: Theme.fs-body;
            font-weight: active-tab == idx ? 700 : 400;
            color: active-tab == idx ? Theme.primary : Theme.muted;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.selected(root.idx); } }
}

component hash-row inherits Rectangle {
    in property <string> algo;
    // 对话框开关：变化时清空已算结果，避免切换文件后显示旧值
    in property <bool> reset-key;
    property <string> computed;
    // 合法哈希为定长十六进制串；错误/提示文案长度不会恰好命中这些值
    property <bool> has-value: root.computed.character-count == 32
        || root.computed.character-count == 40
        || root.computed.character-count == 64
        || root.computed.character-count == 128;

    changed reset-key => { root.computed = ""; }

    height: 40px;
    HorizontalLayout {
        spacing: 8px;
        Text { text: algo; width: 70px; font-size: Theme.fs-small; font-weight: 700; color: Theme.text; vertical-alignment: center; }
        Rectangle {
            horizontal-stretch: 1;
            border-radius: 7px;
            background: #f2f6fa;
            clip: true;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px;
                Text {
                    text: root.computed == "" ? "等待计算" : root.computed;
                    font-size: Theme.fs-tiny;
                    color: #29435d;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
        MiniBtn {
            label: "计算";
            clicked => { root.computed = AppState.compute-hash(root.algo); }
        }
        MiniBtn {
            label: "复制";
            enabled-look: root.has-value;
            clicked => { if (root.has-value) { AppState.copy-text(root.computed); } }
        }
    }
}

component PropRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 32px;
    HorizontalLayout {
        spacing: 12px;
        Text { text: label; width: 92px; font-size: Theme.fs-body; color: Theme.muted; vertical-alignment: center; }
        Text { text: value; font-size: Theme.fs-body; color: Theme.text; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
    }
    Rectangle { y: parent.height - 1px; height: 1px; background: #23374712; }
}

// 「打开方式」行：左标签 + 程序名 + 行内「更改」按钮，对照设计稿 .prop-row
component OpenWithRow inherits Rectangle {
    in property <string> app-name;
    callback change-clicked;
    height: 38px;
    HorizontalLayout {
        spacing: 12px;
        Text { text: "打开方式"; width: 92px; font-size: Theme.fs-body; color: Theme.muted; vertical-alignment: center; }
        Text {
            text: root.app-name == "" ? "未关联应用" : root.app-name;
            font-size: Theme.fs-body;
            color: root.app-name == "" ? Theme.muted : Theme.text;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        MiniBtn {
            label: "更改";
            clicked => { root.change-clicked(); }
        }
    }
    Rectangle { y: parent.height - 1px; height: 1px; background: #23374712; }
}

component DlgBtn inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked;
    min-height: 34px;
    min-width: 64px;
    border-radius: Theme.radius-btn;
    border-width: 1px;
    border-color: primary ? Theme.primary : Theme.border;
    background: primary ? Theme.primary : (touch.has-hover ? #f0f5fa : Theme.surface);
    HorizontalLayout {
        padding-left: 14px; padding-right: 14px;
        Text {
            text: label;
            font-size: Theme.fs-body;
            color: primary ? #ffffff : #284057;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

// 属性对话框，对照 design_ref 的 .properties-modal
export component PropertiesDialog inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> active-tab: 0;
    // 校验区输入（结果在 AppState.verify-result/verify-status，每次打开清空）
    property <string> verify-input;

    changed open => {
        if (root.open) {
            root.verify-input = "";
            AppState.verify-result = "";
            AppState.verify-status = 0;
        }
    }

    visible: open;
    // 遮罩
    Rectangle {
        background: #12223433;
        TouchArea { clicked => { root.open = false; } }
    }

    Rectangle {
        width: 500px;
        height: 540px;
        y: 60px;
        border-radius: Theme.radius-dialog;
        background: Theme.surface;
        border-width: 1px;
        border-color: #ffffffcc;
        drop-shadow-blur: 40px;
        drop-shadow-color: #1c304a4d;
        clip: true;
        TouchArea {}

        VerticalLayout {
            // 头部
            Rectangle {
                height: 88px;
                HorizontalLayout {
                    padding: 18px;
                    padding-left: 20px;
                    spacing: 12px;
                    FileIcon {
                        icon-class: AppState.sel-icon-class;
                        label: AppState.sel-icon-label;
                        box: 52px;
                        radius: 12px;
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 3px;
                        Text { text: AppState.sel-name; font-size: 18px; font-weight: 700; color: Theme.text; overflow: elide; }
                        Text { text: AppState.sel-kind; font-size: Theme.fs-small; color: Theme.muted; }
                    }
                }
                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
            }

            // 选项卡
            Rectangle {
                height: 44px;
                HorizontalLayout {
                    padding-left: 14px;
                    padding-top: 10px;
                    spacing: 4px;
                    alignment: start;
                    tab-btn { label: "常规"; idx: 0; active-tab: root.active-tab; selected(i) => { root.active-tab = i; } }
                    tab-btn { label: "哈希校验"; idx: 1; active-tab: root.active-tab; selected(i) => { root.active-tab = i; } }
                    tab-btn { label: "安全"; idx: 2; active-tab: root.active-tab; selected(i) => { root.active-tab = i; } }
                    tab-btn { label: "数字签名"; idx: 3; active-tab: root.active-tab; selected(i) => { root.active-tab = i; } }
                    tab-btn { label: "详细信息"; idx: 4; active-tab: root.active-tab; selected(i) => { root.active-tab = i; } }
                }
            }

            // 内容
            Rectangle {
                VerticalLayout {
                    padding: 16px;
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 0px;

                    if root.active-tab == 0: VerticalLayout {
                        spacing: 0px;
                        PropRow { label: "类型"; value: AppState.sel-kind; }
                        // 「打开方式」：仅文件显示（文件夹无关联程序）
                        if AppState.sel-open-with != "": OpenWithRow {
                            app-name: AppState.sel-open-with;
                            change-clicked => { AppState.open-with-dialog(); }
                        }
                        PropRow { label: "位置"; value: AppState.sel-location; }
                        PropRow { label: "大小"; value: AppState.sel-size; }
                        PropRow { label: "创建时间"; value: AppState.sel-created; }
                        PropRow { label: "修改时间"; value: AppState.sel-modified; }
                    }

                    if root.active-tab == 1: VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "点击\"计算\"对选中文件做真实哈希运算, \"复制\"可拷贝结果";
                            font-size: Theme.fs-small;
                            color: Theme.muted;
                        }
                        hash-row { algo: "MD5"; reset-key: root.open; }
                        hash-row { algo: "SHA-1"; reset-key: root.open; }
                        hash-row { algo: "SHA-256"; reset-key: root.open; }
                        hash-row { algo: "SHA-512"; reset-key: root.open; }

                        // 分隔线
                        Rectangle { height: 1px; background: #23374712; }

                        // ── 校验区：粘贴期望值，自动识别算法比对 ──
                        Text {
                            text: "哈希校验";
                            font-size: Theme.fs-small;
                            font-weight: 700;
                            color: Theme.text;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                horizontal-stretch: 1;
                                placeholder-text: "粘贴期望的哈希值, 自动识别算法";
                                text <=> root.verify-input;
                                accepted => { AppState.verify-hash(root.verify-input); }
                            }
                            MiniBtn {
                                label: "校验";
                                clicked => { AppState.verify-hash(root.verify-input); }
                            }
                        }
                        Text {
                            text: AppState.verify-result;
                            font-size: Theme.fs-small;
                            font-weight: 700;
                            color: AppState.verify-status == 1 ? #107c10
                                : (AppState.verify-status == 2 ? #d13438 : Theme.muted);
                            wrap: word-wrap;
                        }
                    }

                    // ── 安全页：所有者 + 属性摘要 + DACL 访问控制项 ──
                    if root.active-tab == 2: VerticalLayout {
                        spacing: 0px;
                        PropRow { label: "所有者"; value: AppState.sel-owner; }
                        PropRow { label: "文件属性"; value: AppState.sel-attributes; }
                        PropRow { label: "只读"; value: AppState.sel-readonly ? "是" : "否"; }
                        // DACL 访问控制项
                        VerticalLayout {
                            padding-top: 14px;
                            spacing: 6px;
                            Text {
                                text: "访问控制 (ACL)";
                                font-size: Theme.fs-small;
                                font-weight: 700;
                                color: Theme.text;
                            }
                            if AppState.sel-acl-entries.length == 0: Text {
                                text: "无访问控制项或无法读取";
                                font-size: Theme.fs-small;
                                color: Theme.muted;
                            }
                            for ace[i] in AppState.sel-acl-entries: HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: 44px;
                                    height: 22px;
                                    border-radius: 4px;
                                    background: ace.kind == "拒绝" ? #fbe9e7 : #e3f2fd;
                                    Text {
                                        text: ace.kind;
                                        font-size: 11px;
                                        color: ace.kind == "拒绝" ? #d13438 : #1f6feb;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: ace.trustee;
                                    font-size: Theme.fs-small;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Text {
                                    text: ace.access;
                                    font-size: Theme.fs-small;
                                    color: Theme.muted;
                                    vertical-alignment: center;
                                    width: 120px;
                                    overflow: elide;
                                }
                            }
                        }
                    }

                    // ── 数字签名页 ──
                    if root.active-tab == 3: VerticalLayout {
                        spacing: 12px;
                        padding-top: 4px;
                        HorizontalLayout {
                            spacing: 10px;
                            // 状态圆点：绿色已签名 / 红色未签名 / 灰色不适用或错误
                            Rectangle {
                                width: 14px; height: 14px; y: 3px;
                                border-radius: 7px;
                                background: AppState.sel-sign-status == 1 ? #107c10
                                    : (AppState.sel-sign-status == 2 ? #d13438 : Theme.muted);
                            }
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: AppState.sel-sign-status == 1 ? "已数字签名"
                                        : (AppState.sel-sign-status == 2 ? "未数字签名"
                                        : (AppState.sel-sign-status == 3 ? "无法读取签名信息" : "此文件类型无数字签名"));
                                    font-size: Theme.fs-body;
                                    font-weight: 700;
                                    color: Theme.text;
                                }
                                Text {
                                    text: AppState.sel-sign-detail;
                                    font-size: Theme.fs-small;
                                    color: Theme.muted;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: #23374712; }
                        Text {
                            text: "说明: 此处仅检测可执行文件 (exe/dll/sys 等) 是否内嵌 Authenticode 签名, 不校验证书链有效性. 完整验证请使用系统属性对话框";
                            font-size: Theme.fs-small;
                            color: Theme.muted;
                            wrap: word-wrap;
                        }

                        // 证书链
                        if AppState.sel-cert-chain.length > 0: VerticalLayout {
                            spacing: 6px;
                            padding-top: 6px;
                            Rectangle { height: 1px; background: #23374712; }
                            Text {
                                text: "证书链";
                                font-size: Theme.fs-small;
                                font-weight: 700;
                                color: Theme.text;
                            }
                            for cert[i] in AppState.sel-cert-chain: VerticalLayout {
                                spacing: 2px;
                                PropRow { label: "使用者"; value: cert.subject; }
                                PropRow { label: "颁发者"; value: cert.issuer; }
                                PropRow { label: "有效期起"; value: cert.valid-from; }
                                PropRow { label: "有效期止"; value: cert.valid-to; }
                                if i < AppState.sel-cert-chain.length - 1: Rectangle { height: 1px; background: #2337470a; }
                            }
                        }
                    }

                    // ── 详细信息页：EXIF / 音频标签 / Office 核心属性 ──
                    if root.active-tab == 4: VerticalLayout {
                        spacing: 0px;
                        if AppState.sel-meta-rows.length == 0: Text {
                            text: "无扩展元数据";
                            font-size: Theme.fs-small;
                            color: Theme.muted;
                        }
                        for row[i] in AppState.sel-meta-rows: PropRow {
                            label: row.label;
                            value: row.value;
                        }
                    }
                }
            }

            Rectangle { }

            // 底部按钮
            Rectangle {
                height: 64px;
                Rectangle { y: 0; height: 1px; background: Theme.border; }
                HorizontalLayout {
                    padding: 14px;
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 8px;
                    alignment: end;
                    DlgBtn { label: "确定"; primary: true; clicked => { root.open = false; } }
                    DlgBtn { label: "取消"; clicked => { root.open = false; } }
                    DlgBtn { label: "应用"; clicked => { root.open = false; } }
                }
            }
        }
    }
}
