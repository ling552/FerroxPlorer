import { Theme } from "theme.slint";
import { AppState, NavItem } from "globals.slint";
import { FileIcon } from "file_icon.slint";

export component Sidebar inherits Rectangle {
    background: Theme.surface-2.with-alpha(Theme.panel-alpha);
    width: Theme.sidebar-w;
    border-radius: Theme.radius-card;
    clip: true;

    flick := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: max(content.preferred-height, parent.height);

        content := VerticalLayout {
            padding: 12px;
            padding-left: 10px;
            padding-right: 10px;
            spacing: 1px;

            for item[idx] in AppState.nav-items: Rectangle {
                // 为 for 外层显式指定高度，避免 VerticalLayout 中条目重叠
                // （磁盘与设备节点同为两行布局：磁盘多一条容量进度条故稍高；
                //   「此电脑」树节点与分区标题同高保持视觉一致）
                height: item.is-header || item.is-tree ? 30px
                    : (item.is-disk ? 54px
                        : (item.icon-class == "device" ? 50px : Theme.row-h));

                // ── 分区标题（快速访问 / 标签 / 系统）：整行点击折叠 ──
                if item.is-header: Rectangle {
                    background: head-touch.has-hover ? Theme.primary-hover : transparent;
                    border-radius: Theme.radius-btn;
                    head-touch := TouchArea { clicked => { AppState.toggle-section(item.label); } }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 8px;
                        padding-top: 6px;
                        Text {
                            text: item.label;
                            font-size: Theme.fs-small;
                            color: Theme.subtle;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        Rectangle { }
                        // MDL2 折叠箭头：展开向下(E70D)，折叠向右(E76C)
                        Text {
                            text: item.collapsed ? "\u{E76C}" : "\u{E70D}";
                            font-family: "Segoe MDL2 Assets";
                            font-size: 10px;
                            color: Theme.subtle;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── 树节点表头（此电脑）：无图标；文字点击进入"此电脑"界面，右侧 chevron 折叠驱动器列表 ──
                if item.is-tree: Rectangle {
                    border-radius: Theme.radius-btn;
                    background: item.active ? Theme.primary-soft : (tree-touch.has-hover ? Theme.primary-hover : transparent);
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 8px; spacing: 4px;
                        // 文字（点击进入此电脑界面），占据左侧主要宽度；
                        // 左对齐、字号/颜色/字重与其他分区标题（快速访问/标签）一致
                        tree-touch := TouchArea {
                            horizontal-stretch: 1;
                            clicked => { AppState.navigate(item.path); }
                            Text {
                                text: item.label;
                                width: parent.width;
                                height: parent.height;
                                font-size: Theme.fs-small;
                                // hover 变主色提示「可点击导航」，与纯折叠用的分区标题区分
                                color: item.active || tree-touch.has-hover ? Theme.primary : Theme.subtle;
                                font-weight: 700;
                                horizontal-alignment: left;
                                vertical-alignment: center; overflow: elide;
                            }
                        }
                        // chevron 折叠/展开开关（右侧独立命中区，与分区标题一致）
                        chev-touch := TouchArea {
                            width: 20px;
                            clicked => { AppState.toggle-section(item.label); }
                            Text {
                                text: item.collapsed ? "\u{E76C}" : "\u{E70D}";
                                font-family: "Segoe MDL2 Assets";
                                font-size: 10px;
                                color: chev-touch.has-hover ? Theme.primary : Theme.subtle;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── 驱动器条目：矢量盘符图标 + 名称 + 使用率进度条（缩进对齐树节点子项）──
                if item.is-disk: Rectangle {
                    border-radius: Theme.radius-btn;
                    background: item.active ? Theme.primary-soft : (disk-touch.has-hover ? Theme.primary-hover : transparent);
                    disk-touch := TouchArea { clicked => { AppState.navigate(item.path); } }
                    HorizontalLayout {
                        padding: 8px; padding-left: 22px; spacing: 8px; alignment: start;
                        FileIcon {
                            icon-class: item.icon-class;
                            thumb: item.thumb;
                            has-thumb: item.has-thumb;
                            box: 22px; radius: 5px; y: 2px;
                        }
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: item.label; font-size: Theme.fs-body; color: item.active ? Theme.primary : Theme.text; font-weight: 600; overflow: elide; }
                            Text { text: item.disk-info; font-size: Theme.fs-tiny; color: Theme.muted; overflow: elide; }
                            Rectangle {
                                height: 4px; border-radius: 2px; background: #dce6f0; clip: true;
                                Rectangle { x: 0; width: parent.width * item.disk-ratio; height: parent.height; border-radius: 2px; background: item.disk-color; }
                            }
                        }
                    }
                }

                // ── 便携设备条目：与驱动器条目同款两行布局（22px 图标 + 名称 + 类型副标题），
                //    缩进/字号/字重与磁盘节点统一，仅无容量进度条 ──
                if !item.is-header && !item.is-tree && !item.is-disk && item.icon-class == "device": Rectangle {
                    border-radius: Theme.radius-btn;
                    background: item.active ? Theme.primary-soft : (dev-touch.has-hover ? Theme.primary-hover : transparent);
                    dev-touch := TouchArea { clicked => { AppState.navigate(item.path); } }
                    HorizontalLayout {
                        padding: 8px; padding-left: 22px; spacing: 8px; alignment: start;
                        FileIcon {
                            icon-class: "device";
                            thumb: item.thumb;
                            has-thumb: item.has-thumb;
                            box: 22px; radius: 5px; y: 2px;
                        }
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: item.label; font-size: Theme.fs-body; color: item.active ? Theme.primary : Theme.text; font-weight: 600; overflow: elide; }
                            Text { text: "便携设备"; font-size: Theme.fs-tiny; color: Theme.muted; overflow: elide; }
                        }
                    }
                }

                // ── 普通导航项（快速访问 / 标签 / 系统）──
                if !item.is-header && !item.is-tree && !item.is-disk && item.icon-class != "device": Rectangle {
                    border-radius: Theme.radius-btn;
                    background: item.active ? Theme.primary-soft : (nav-touch.has-hover ? Theme.primary-hover : transparent);
                    nav-touch := TouchArea { clicked => { AppState.navigate(item.path); } }
                    HorizontalLayout {
                        padding-left: 9px; padding-right: 9px; spacing: 8px;
                        // 系统图标模式：显示系统提取的文件夹图标
                        if item.has-thumb: FileIcon {
                            icon-class: "folder";
                            thumb: item.thumb;
                            has-thumb: true;
                            box: 18px; radius: 5px; y: (parent.height - 18px) / 2;
                        }
                        // 已知系统文件夹（桌面/下载/文档/图片/音乐/视频/主目录）：专属 MDL2 图标
                        if !item.has-thumb && item.icon-class == "qa-glyph": Rectangle {
                            width: 18px; height: 18px; y: (parent.height - 18px) / 2;
                            Text {
                                width: 100%; height: 100%;
                                text: item.icon;
                                font-family: "Segoe MDL2 Assets";
                                font-size: 14px;
                                color: item.active ? Theme.primary : Theme.muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        // 内置图标模式：首字符色块
                        if !item.has-thumb && item.icon-class != "qa-glyph" && item.icon != "●": Rectangle {
                            width: 18px; height: 18px; y: (parent.height - 18px) / 2;
                            border-radius: 5px; background: #e8f3ff;
                            border-width: 1px; border-color: #0078d424;
                            Text { text: item.icon; font-size: Theme.fs-tiny; color: Theme.primary; font-weight: 800; }
                        }
                        if !item.has-thumb && item.icon == "●": Rectangle {
                            width: 10px; height: 10px; y: (parent.height - 10px) / 2;
                            border-radius: 5px; background: item.disk-color;
                        }
                        Text {
                            text: item.label;
                            font-size: Theme.fs-body;
                            color: item.active ? Theme.primary : Theme.text;
                            font-weight: item.active ? 700 : 400;
                            vertical-alignment: center; overflow: elide;
                            horizontal-stretch: 1;
                        }
                        if item.badge != "": Rectangle {
                            y: (parent.height - 20px) / 2; height: 20px; min-width: 20px;
                            border-radius: 10px; background: #eef3f8;
                            HorizontalLayout {
                                padding-left: 6px; padding-right: 6px;
                                Text { text: item.badge; font-size: Theme.fs-tiny; color: Theme.muted; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }
        }
    }
}
