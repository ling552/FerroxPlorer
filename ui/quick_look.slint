import { Theme } from "theme.slint";
import { AppState } from "globals.slint";
import { FileIcon } from "file_icon.slint";
import { ScrollView } from "std-widgets.slint";

// 空格键 Quick Look 预览浮层，类 macOS「快速查看」。
// 居中卡片：顶部标题栏 + 中部按 ql-kind 切换的内容区。
// 图标优先使用条目的真实缩略图/系统图标（ql-thumb），配色随主题（含深色）。
// 关闭：点击遮罩、再次按空格或 Esc（键由 main.slint 的 FocusScope 处理）。
export component QuickLook inherits Rectangle {
    visible: AppState.quicklook-open;

    background: AppState.ql-video-fullscreen ? black : transparent;

    // 半透明遮罩：点击关闭；视频全屏时作为纯黑留边背景。
    Rectangle {
        background: AppState.ql-video-fullscreen ? black : #12223455;
        TouchArea { clicked => { AppState.close-quicklook(); } }
    }

    // 预览卡片：尺寸由 Rust 按内容类型自适应计算（图片/视频按分辨率、
    // 文件夹紧凑、网页渲染更大；最小 256×256 内容区）
    if !AppState.ql-video-fullscreen: Rectangle {
        width: AppState.ql-card-w;
        height: AppState.ql-card-h;
        border-radius: Theme.radius-dialog;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 48px;
        drop-shadow-color: #1c304a55;
        clip: true;
        // 吞掉卡片内部点击，避免穿透到遮罩导致误关
        TouchArea {}

        VerticalLayout {
            // 头部：图标 + 名称 + 副标题 + 关闭按钮
            Rectangle {
                height: 64px;
                HorizontalLayout {
                    padding: 14px;
                    padding-left: 18px;
                    spacing: 12px;
                    FileIcon {
                        icon-class: AppState.ql-icon-class;
                        thumb: AppState.ql-thumb;
                        has-thumb: AppState.ql-has-thumb;
                        box: 36px;
                        radius: 9px;
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        horizontal-stretch: 1;
                        Text {
                            text: AppState.ql-name;
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text;
                            overflow: elide;
                        }
                        Text {
                            text: AppState.ql-subtitle;
                            font-size: Theme.fs-small;
                            color: Theme.muted;
                            overflow: elide;
                        }
                    }
                    // 渲染/源码 视图切换（仅 Markdown/HTML/PHP 等可渲染文件显示）
                    if AppState.ql-can-render: Rectangle {
                        width: 116px; height: 30px;
                        y: 4px;
                        border-radius: 8px;
                        background: Theme.surface-2;
                        border-width: 1px;
                        border-color: Theme.border;
                        HorizontalLayout {
                            padding: 2px;
                            spacing: 2px;
                            Rectangle {
                                border-radius: 6px;
                                background: AppState.ql-web-mode ? Theme.primary-soft : (render-btn.has-hover ? Theme.primary-hover : transparent);
                                Text {
                                    text: "渲染";
                                    font-size: Theme.fs-tiny;
                                    color: AppState.ql-web-mode ? Theme.primary : Theme.muted;
                                    font-weight: AppState.ql-web-mode ? 700 : 400;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                render-btn := TouchArea { clicked => { AppState.ql-set-web-mode(true); } }
                            }
                            Rectangle {
                                border-radius: 6px;
                                background: !AppState.ql-web-mode ? Theme.primary-soft : (source-btn.has-hover ? Theme.primary-hover : transparent);
                                Text {
                                    text: "源码";
                                    font-size: Theme.fs-tiny;
                                    color: !AppState.ql-web-mode ? Theme.primary : Theme.muted;
                                    font-weight: !AppState.ql-web-mode ? 700 : 400;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                source-btn := TouchArea { clicked => { AppState.ql-set-web-mode(false); } }
                            }
                        }
                    }
                    // 视频全屏按钮
                    if AppState.ql-kind == 4: Rectangle {
                        width: 30px; height: 30px;
                        y: 4px;
                        border-radius: 8px;
                        background: fsbtn.has-hover ? Theme.primary-hover : transparent;
                        Text {
                            text: AppState.ql-video-fullscreen ? "\u{E73F}" : "\u{E740}";
                            font-family: "Segoe MDL2 Assets";
                            font-size: 14px;
                            color: fsbtn.has-hover ? Theme.primary : Theme.muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        fsbtn := TouchArea { clicked => { AppState.ql-toggle-video-fullscreen(); } }
                    }
                    // 关闭按钮（MDL2 图标，与标题栏风格一致）
                    Rectangle {
                        width: 30px; height: 30px;
                        y: 4px;
                        border-radius: 8px;
                        background: closebtn.has-hover ? Theme.primary-hover : transparent;
                        Text {
                            text: "\u{E711}";
                            font-family: "Segoe MDL2 Assets";
                            font-size: 12px;
                            color: closebtn.has-hover ? Theme.primary : Theme.muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        closebtn := TouchArea { clicked => { AppState.close-quicklook(); } }
                    }
                }
                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
            }

            // 内容区（次级表面色，深浅主题自适应）
            Rectangle {
                vertical-stretch: 1;
                background: Theme.surface-2;
                clip: true;

                // 图片预览（ql-kind == 1）：按真实像素显示，滚轮缩放、拖动查看。
                // 卡片已按图片宽高比自适应，初始缩放正好铺满内容区无空白
                if AppState.ql-kind == 1: img-area := Rectangle {
                    clip: true;
                    // 自适应初始缩放：能放下就 1:1（小图不放大），放不下缩小到刚好容纳
                    property <float> fit-zoom: min(1.0, min(
                        self.width / max(1px, AppState.ql-img-w * 1px),
                        self.height / max(1px, AppState.ql-img-h * 1px)));
                    // 手动缩放倍率；<=0 表示未手动调整（跟随自适应）
                    property <float> user-zoom: 0;
                    property <float> zoom: img-area.user-zoom > 0 ? img-area.user-zoom : img-area.fit-zoom;
                    // 拖动偏移与可拖范围（图片超出可视区的一半；不超出时钉在中心）
                    property <length> off-x: 0px;
                    property <length> off-y: 0px;
                    property <length> max-off-x: max(0px, (AppState.ql-img-w * 1px * img-area.zoom - self.width) / 2);
                    property <length> max-off-y: max(0px, (AppState.ql-img-h * 1px * img-area.zoom - self.height) / 2);
                    // 切换到另一张图片时重置缩放与偏移
                    property <string> cur-img: AppState.ql-name;
                    changed cur-img => { self.user-zoom = 0; self.off-x = 0px; self.off-y = 0px; }

                    if AppState.ql-has-image: Image {
                        x: (img-area.width - self.width) / 2 + clamp(img-area.off-x, -img-area.max-off-x, img-area.max-off-x);
                        y: (img-area.height - self.height) / 2 + clamp(img-area.off-y, -img-area.max-off-y, img-area.max-off-y);
                        width: max(1px, AppState.ql-img-w * 1px * img-area.zoom);
                        height: max(1px, AppState.ql-img-h * 1px * img-area.zoom);
                        source: AppState.ql-image;
                        image-fit: fill;
                    }
                    if !AppState.ql-has-image: Text {
                        text: "正在生成预览…";
                        font-size: Theme.fs-body;
                        color: Theme.muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    // 拖动 + 滚轮缩放交互层
                    if AppState.ql-has-image: TouchArea {
                        mouse-cursor: self.pressed ? MouseCursor.grabbing : MouseCursor.grab;
                        property <length> press-off-x: 0px;
                        property <length> press-off-y: 0px;
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                self.press-off-x = img-area.off-x;
                                self.press-off-y = img-area.off-y;
                            }
                        }
                        moved => {
                            img-area.off-x = clamp(self.press-off-x + (self.mouse-x - self.pressed-x), -img-area.max-off-x, img-area.max-off-x);
                            img-area.off-y = clamp(self.press-off-y + (self.mouse-y - self.pressed-y), -img-area.max-off-y, img-area.max-off-y);
                        }
                        scroll-event(ev) => {
                            // 滚轮缩放（5%..800%），缩放中心为视图中心
                            img-area.user-zoom = clamp(img-area.zoom * (ev.delta-y > 0 ? 1.15 : 1 / 1.15), 0.05, 8.0);
                            return accept;
                        }
                    }

                    // 缩放百分比角标
                    if AppState.ql-has-image: Rectangle {
                        x: parent.width - self.width - 10px;
                        y: 10px;
                        width: zoom-label.preferred-width + 16px;
                        height: 24px;
                        border-radius: 7px;
                        background: #00000066;
                        zoom-label := Text {
                            width: 100%;
                            height: 100%;
                            text: round(img-area.zoom * 100) + "%";
                            color: white;
                            font-size: Theme.fs-tiny;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // 网页渲染视图（ql-kind == 2 且渲染模式）：白底衬托；
                // 页面由 WebView2 原生子窗口覆盖渲染，本层只作背景与加载提示
                if AppState.ql-kind == 2 && AppState.ql-web-mode: Rectangle {
                    background: white;
                    Text {
                        text: "正在加载渲染视图…";
                        font-size: Theme.fs-body;
                        color: #66707a;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // 文本/代码预览（ql-kind == 2 源码模式）：单层等宽文本保证行高与字形稳定。
                // Slint Text 不支持富文本，多层字符遮罩在混合中英文时会产生基线偏移。
                if AppState.ql-kind == 2 && !AppState.ql-web-mode: ScrollView {
                    VerticalLayout {
                        padding: 16px;
                        code-base := Text {
                            text: AppState.ql-text;
                            font-size: Theme.fs-small;
                            font-family: "Consolas";
                            color: Theme.text;
                            horizontal-alignment: left;
                            vertical-alignment: top;
                        }
                    }
                }

                // 视频预览（ql-kind == 4）：黑底衬托；画面由 Media Foundation
                // 子窗口覆盖渲染（含音频），本层只作背景与启动提示
                if AppState.ql-kind == 4: Rectangle {
                    background: black;
                    Text {
                        text: "正在启动播放…";
                        font-size: Theme.fs-body;
                        color: #9aa7b5;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // 文件夹（3）/ 其它信息（0）：大图标衬底 + 名称 + 信息行
                if AppState.ql-kind == 0 || AppState.ql-kind == 3: VerticalLayout {
                    alignment: center;
                    spacing: 14px;
                    HorizontalLayout {
                        alignment: center;
                        // 图标衬底：柔和圆角底板，突出主体
                        Rectangle {
                            width: 132px;
                            height: 132px;
                            border-radius: 24px;
                            background: Theme.surface.with-alpha(Theme.dark ? 0.35 : 0.75);
                            border-width: 1px;
                            border-color: Theme.border;
                            FileIcon {
                                icon-class: AppState.ql-icon-class;
                                thumb: AppState.ql-thumb;
                                has-thumb: AppState.ql-has-thumb;
                                box: 96px;
                                radius: 18px;
                                x: (parent.width - 96px) / 2;
                                y: (parent.height - 96px) / 2;
                            }
                        }
                    }
                    Text {
                        text: AppState.ql-name;
                        font-size: 16px;
                        font-weight: 700;
                        color: Theme.text;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        text: AppState.ql-info;
                        font-size: Theme.fs-body;
                        color: Theme.muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }

            // 底部提示
            Rectangle {
                height: 38px;
                background: Theme.surface;
                Rectangle { y: 0; height: 1px; background: Theme.border; }
                Text {
                    text: AppState.ql-kind == 1
                        ? "滚轮缩放 · 拖动查看 · 按 空格 或 Esc 关闭"
                        : "按 空格 或 Esc 关闭预览";
                    font-size: Theme.fs-tiny;
                    color: Theme.muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
