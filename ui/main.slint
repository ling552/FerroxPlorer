import { Theme } from "theme.slint";
import { AppState } from "globals.slint";
import { Sidebar } from "sidebar.slint";
import { Toolbar } from "toolbar.slint";
import { FileGrid } from "file_grid.slint";
import { FileList } from "file_list.slint";
import { ThisPcView } from "this_pc_view.slint";
import { DetailsPane } from "details_pane.slint";
import { PropertiesDialog } from "properties_dialog.slint";
import { QuickLook } from "quick_look.slint";
import { CommandPalette } from "command_palette.slint";
import { DualPane } from "dual_pane.slint";
import { ProgressCard } from "progress_card.slint";
import { ConflictDialog } from "conflict_dialog.slint";
import { NetworkLocationDialog } from "network_dialog.slint";
import { ContextMenu } from "context_menu.slint";
import { SettingsPanel } from "settings_panel.slint";
import { VSplitter } from "splitter.slint";
import { ActionBar } from "action_bar.slint";

export { AppState, Theme }

// 窗口控制按钮（最小化 / 最大化 / 关闭），贴右上角、全高、Windows 11 风格
component WinCtrlBtn inherits Rectangle {
    in property <string> glyph;
    in property <bool> danger: false;
    callback clicked;
    width: 46px;
    background: touch.has-hover ? (danger ? #e81123 : rgba(0, 0, 0, 0.06)) : transparent;
    Text {
        text: glyph;
        font-family: "Segoe MDL2 Assets";
        font-size: 10px;
        color: (danger && touch.has-hover) ? #ffffff : Theme.text;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component MainWindow inherits Window {
    title: "FerroxPlorer";
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 900px;
    min-height: 560px;
    // 窗口本体透明：由根底层 Rectangle 统一绘制背景，半透明模式下桌面可透出。
    background: transparent;
    // 无边框：自绘标题栏，标签页与窗口按钮同行（Windows 资源管理器风格）
    no-frame: true;
    // 边缘 resize 由原生 WM_NCHITTEST subclass 处理（见 main.rs install_native_resize），
    // 不再用 winit resize-border-width--后者在无边框窗口上拖拽会忽大忽小、剧烈抖动。

    // 对话框/菜单控制
    in-out property <bool> props-open <=> props.open;

    // 窗口控制回调（由 Rust 实现：最小化 / 最大化切换 / 关闭 / 拖动）
    callback minimize-window();
    callback toggle-maximize();
    callback close-window();
    callback start-window-drag();
    in-out property <bool> window-maximized: false;

    forward-focus: key-scope;

    // 根外壳：整窗唯一的填充层，承担背景 + 圆角裁切。
    // 半透明模式下按 shell-alpha 透出 DWM 亚克力真实磨砂（blur 越大越透越模糊）；
    // 半透明且非最大化时启用 Slint 圆角 + clip，形成圆角磨砂玻璃面板；
    // 不透明 / 最大化时归零，交由 DWM 窗口圆角处理，避免四角透出瑕疵。
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: (Theme.translucent && !root.window-maximized) ? Theme.radius-shell : 0px;
        clip: true;
        background: Theme.bg.with-alpha(Theme.shell-alpha);

    key-scope := FocusScope {
        width: 100%;
        height: 100%;
        // 全局快捷键
        key-pressed(ev) => {
            // Quick Look 已打开：空格 / Esc 关闭，吞掉其它按键避免误触
            if (AppState.quicklook-open) {
                if (ev.text == " " || ev.text == Key.Escape) {
                    AppState.close-quicklook();
                    return accept;
                }
                return accept;
            }
            // 空格键 Quick Look 预览：仅在非重命名编辑（任一面板）、非命令面板时触发
            if (ev.text == " " && AppState.editing-index == -1 && AppState.r-editing-index == -1
                && !AppState.command-palette-open) {
                AppState.open-quicklook();
                return accept;
            }

            // 命令面板：Ctrl+P 或 Esc 关闭
            if (ev.modifiers.control && ev.text == "p") {
                AppState.command-palette-open = !AppState.command-palette-open;
                // 打开时用空查询初始化命令列表（显示全部命令）
                if (AppState.command-palette-open) { AppState.palette-query(""); }
                return accept;
            }
            if (ev.text == Key.Escape && AppState.command-palette-open) {
                AppState.command-palette-open = false;
                return accept;
            }

            if (ev.text == Key.F2) {
                AppState.request-rename();
                return accept;
            }
            if (ev.text == Key.Delete) {
                AppState.delete-selected();
                return accept;
            }
            if (ev.text == Key.F5) {
                AppState.refresh();
                return accept;
            }
            if (ev.text == Key.Backspace) {
                AppState.go-up();
                return accept;
            }
            if (ev.modifiers.control && ev.text == "c") { AppState.copy-selected(); return accept; }
            if (ev.modifiers.control && !ev.modifiers.shift && ev.text == "z") { AppState.undo(); return accept; }
            if (ev.modifiers.control && ev.modifiers.shift && (ev.text == "z" || ev.text == "Z")) { AppState.redo(); return accept; }
            if (ev.modifiers.control && ev.text == "x") { AppState.cut-selected(); return accept; }
            if (ev.modifiers.control && ev.text == "v") { AppState.paste-here(); return accept; }
            if (ev.modifiers.control && ev.text == "a") { AppState.select-all(); return accept; }
            if (ev.modifiers.control && ev.text == "f") { AppState.set-omni-mode("search"); return accept; }
            if (ev.modifiers.control && ev.modifiers.shift && ev.text == "n") { AppState.new-folder(); return accept; }
            if (ev.modifiers.control && ev.text == "t") { AppState.new-tab(); return accept; }
            return reject;
        }

        VerticalLayout {
            spacing: 0px;

            // 标题栏：品牌图标 + 标签页 + 窗口控制按钮（无边框，三按钮同行）
            Rectangle {
                height: 48px;
                background: Theme.shell.with-alpha(Theme.panel-alpha);
                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }

                // 标题栏拖动层：铺满整条标题栏、声明在最底层（z 最低）。标签页 / 窗口按钮
                // 在其之上，优先捕获各自点击；空白处的按下落到此层触发窗口拖动 / 双击最大化。
                TouchArea {
                    mouse-cursor: move;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                            root.start-window-drag();
                        }
                    }
                    double-clicked => { root.toggle-maximize(); }
                }

                HorizontalLayout {
                    spacing: 0px;
                    // 左侧留白
                    Rectangle { width: 8px; }
                    // 品牌图标（显示 icon.png；双击最大化；拖动由底层标题栏拖动层统一处理）
                    Rectangle {
                        width: 34px; height: 34px;
                        y: (parent.height - 34px)/2;
                        border-radius: 8px;
                        background: @linear-gradient(135deg, #0078d4, #35b8ff);
                        drop-shadow-blur: 10px;
                        drop-shadow-color: rgba(0, 120, 212, 0.28);
                        clip: true;
                        Image {
                            width: 100%; height: 100%;
                            source: @image-url("../icon.png");
                            image-fit: contain;
                        }
                        brand-drag := TouchArea {
                            mouse-cursor: move;
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                    root.start-window-drag();
                                }
                            }
                            double-clicked => { root.toggle-maximize(); }
                        }
                    }
                    // 标签页列表区
                    tab-row := HorizontalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;
                        padding-left: 8px;
                        alignment: start;
                        // 渲染全部标签页（点击切换 / 拖动重排 / 关闭）
                        for tab[i] in AppState.tabs: Rectangle {
                            y: (parent.height - 40px)/2;
                            height: 40px;
                            width: 184px;
                            border-radius: 10px;
                            background: tab.active
                                ? rgba(255, 255, 255, 0.92)
                                : (tab-touch.has-hover ? rgba(255, 255, 255, 0.5) : transparent);
                            drop-shadow-blur: tab.active ? 4px : 0px;
                            drop-shadow-color: rgba(0, 0, 0, 0.06);

                            // 底层：切换 + 拖动重排（声明在内容之前，置于下层；关闭按钮在上层优先响应）
                            tab-touch := TouchArea {
                                mouse-cursor: pointer;
                                property <length> press-x: 0px;
                                property <bool> dragged: false;
                                pointer-event(ev) => {
                                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                        self.press-x = self.mouse-x;
                                        self.dragged = false;
                                    }
                                    if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                        if (self.mouse-x - self.press-x > 92px) {
                                            AppState.move-tab(i, min(i + 1, AppState.tabs.length - 1));
                                        } else if (self.press-x - self.mouse-x > 92px) {
                                            AppState.move-tab(i, max(i - 1, 0));
                                        }
                                    }
                                }
                                moved => {
                                    if (abs(self.mouse-x - self.press-x) > 6px) { self.dragged = true; }
                                }
                                clicked => {
                                    if (!self.dragged) { AppState.switch-tab(i); }
                                }
                            }

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 8px;
                                spacing: 6px;
                                Rectangle {
                                    width: 14px; height: 14px;
                                    border-radius: 4px;
                                    background: Theme.primary-weak;
                                    y: (parent.height - 14px) / 2;
                                    Text {
                                        text: tab.kind == "settings" ? "\u{E713}" : "\u{E8B7}";
                                        font-family: "Segoe MDL2 Assets";
                                        font-size: 11px;
                                        color: Theme.primary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: tab.title;
                                    font-size: Theme.fs-body;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 20px; height: 20px;
                                    y: (parent.height - 20px) / 2;
                                    border-radius: 5px;
                                    background: ct.has-hover ? rgba(0, 0, 0, 0.08) : transparent;
                                    ct := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { AppState.close-tab-at(i); }
                                    }
                                    Text {
                                        text: "\u{E711}";
                                        font-family: "Segoe MDL2 Assets";
                                        font-size: 9px;
                                        color: Theme.muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        // 新建标签按钮
                        new-tab := Rectangle {
                            y: (parent.height - 32px)/2;
                            width: 32px; height: 32px;
                            border-radius: 8px;
                            background: nt.has-hover ? Theme.primary-hover : transparent;
                            nt := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { AppState.new-tab(); }
                            }
                            Text {
                                text: "+";
                                font-size: 18px;
                                color: Theme.muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    // 窗口控制按钮（贴右上角，全高）
                    HorizontalLayout {
                        spacing: 0px;
                        WinCtrlBtn {
                            glyph: "\u{E921}";   // 最小化
                            clicked => { root.minimize-window(); }
                        }
                        WinCtrlBtn {
                            glyph: root.window-maximized ? "\u{E923}" : "\u{E922}";   // 还原 / 最大化
                            clicked => { root.toggle-maximize(); }
                        }
                        WinCtrlBtn {
                            glyph: "\u{E8BB}";   // 关闭
                            danger: true;
                            clicked => { root.close-window(); }
                        }
                    }
                }
            }

            // 工具栏
            Toolbar {}
            Rectangle { height: 1px; background: Theme.border; }

            // 主体三栏
            Rectangle {
                vertical-stretch: 1;
                // 设置界面（作为独立标签页，全窗口覆盖）
                if AppState.active-view == "settings": SettingsPanel {}
                // 文件浏览（三栏布局，可拖拽调整栏宽）
                if AppState.active-view == "files": HorizontalLayout {
                    spacing: 0px;
                    Sidebar { width: AppState.sidebar-w; }
                    VSplitter {
                        dragged(dx) => {
                            AppState.sidebar-w = clamp(AppState.sidebar-w + dx, 160px, 420px);
                        }
                        committed => {
                            AppState.save-layout(AppState.sidebar-w, AppState.details-w, AppState.col-modified-w, AppState.col-kind-w, AppState.col-size-w);
                        }
                    }

                    // 文件浏览内容区（半透明时融入统一毛玻璃，否则不透明避免透出后方窗口）
                    content := Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.surface.with-alpha(Theme.panel-alpha);
                        VerticalLayout {
                            // 快捷操作栏（始终显示：无选中时操作会被 Rust 端忽略）
                            ActionBar {}

                            // 视图切换：双面板与布局（网格/列表）正交。
                            // dual-pane 为真时进入左右双面板（两侧共享 view-mode 布局）；
                            // 否则单面板按 view-mode 渲染网格 / 列表。
                            Rectangle {
                                vertical-stretch: 1;
                                if AppState.dual-pane: DualPane {
                                    request-context-menu(idx, mx, my) => {
                                        if (AppState.set-context-menu-system) {
                                            if (idx >= 0) {
                                                AppState.show-system-menu(idx, mx + AppState.sidebar-w + 7px, my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h);
                                            }
                                        } else {
                                        // 自定义右键菜单：target 属性按活动面板取对应 entries
                                        ctxmenu.is-background = idx < 0;
                                        ctxmenu.target-index = idx;
                                        ctxmenu.menu-x = mx + AppState.sidebar-w + 7px;
                                        ctxmenu.menu-y = my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h;
                                        if (AppState.active-pane == "right") {
                                            ctxmenu.target-is-dir = idx >= 0 ? AppState.r-entries[idx].is-dir : false;
                                            ctxmenu.target-important = idx >= 0 ? AppState.r-entries[idx].tag-important : false;
                                            ctxmenu.target-archive = idx >= 0 ? AppState.r-entries[idx].tag-archive : false;
                                            ctxmenu.target-done = idx >= 0 ? AppState.r-entries[idx].tag-done : false;
                                        } else {
                                            ctxmenu.target-is-dir = idx >= 0 ? AppState.entries[idx].is-dir : false;
                                            ctxmenu.target-important = idx >= 0 ? AppState.entries[idx].tag-important : false;
                                            ctxmenu.target-archive = idx >= 0 ? AppState.entries[idx].tag-archive : false;
                                            ctxmenu.target-done = idx >= 0 ? AppState.entries[idx].tag-done : false;
                                        }
                                        ctxmenu.open = true;
                                        }
                                    }
                                }
                                // "此电脑"专属平铺视图（优先于网格/列表，与 view-mode 无关）
                                if !AppState.dual-pane && AppState.current-vpath == "this-pc://": Rectangle {
                                    VerticalLayout {
                                        padding: 6px;
                                        ThisPcView {
                                            request-context-menu(idx, mx, my) => {
                                                AppState.show-system-menu(idx, mx + AppState.sidebar-w + 7px + 6px, my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h + 6px);
                                            }
                                        }
                                    }
                                }
                                if !AppState.dual-pane && AppState.current-vpath != "this-pc://" && AppState.view-mode == "grid": Rectangle {
                                    VerticalLayout {
                                        padding: 6px;
                                        FileGrid {
                                            request-context-menu(idx, mx, my) => {
                                                if (AppState.set-context-menu-system) {
                                                    // 系统原生菜单（空白处不弹）
                                                    if (idx >= 0) {
                                                        AppState.show-system-menu(idx, mx + AppState.sidebar-w + 7px + 6px, my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h + 6px);
                                                    }
                                                } else {
                                                    // idx<0 为空白处右键→背景菜单；选中/清除已由 InputOverlay 处理
                                                    ctxmenu.is-background = idx < 0;
                                                    ctxmenu.target-index = idx;
                                                    ctxmenu.menu-x = mx + AppState.sidebar-w + 7px + 6px;
                                                    ctxmenu.menu-y = my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h + 6px;
                                                    ctxmenu.target-is-dir = idx >= 0 ? AppState.entries[idx].is-dir : false;
                                                    ctxmenu.target-important = idx >= 0 ? AppState.entries[idx].tag-important : false;
                                                    ctxmenu.target-archive = idx >= 0 ? AppState.entries[idx].tag-archive : false;
                                                    ctxmenu.target-done = idx >= 0 ? AppState.entries[idx].tag-done : false;
                                                    ctxmenu.open = true;
                                                }
                                            }
                                        }
                                    }
                                }
                                if !AppState.dual-pane && AppState.current-vpath != "this-pc://" && AppState.view-mode == "list": Rectangle {
                                    VerticalLayout {
                                        padding: 6px;
                                        FileList {
                                            request-context-menu(idx, mx, my) => {
                                                if (AppState.set-context-menu-system) {
                                                    if (idx >= 0) {
                                                        // 40px = 内边距 6px + 表头行高 34px
                                                        AppState.show-system-menu(idx, mx + AppState.sidebar-w + 7px + 6px, my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h + 40px);
                                                    }
                                                } else {
                                                    // idx<0 为空白处右键→背景菜单；选中/清除已由 InputOverlay 处理
                                                    ctxmenu.is-background = idx < 0;
                                                    ctxmenu.target-index = idx;
                                                    ctxmenu.menu-x = mx + AppState.sidebar-w + 7px + 6px;
                                                    ctxmenu.menu-y = my + 48px + Theme.toolbar-h + 1px + Theme.actionbar-h + 40px;
                                                    ctxmenu.target-is-dir = idx >= 0 ? AppState.entries[idx].is-dir : false;
                                                    ctxmenu.target-important = idx >= 0 ? AppState.entries[idx].tag-important : false;
                                                    ctxmenu.target-archive = idx >= 0 ? AppState.entries[idx].tag-archive : false;
                                                    ctxmenu.target-done = idx >= 0 ? AppState.entries[idx].tag-done : false;
                                                    ctxmenu.open = true;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // 详情面板（可拖拽调整宽度）
                    if AppState.show-details: VSplitter {
                        dragged(dx) => {
                            AppState.details-w = clamp(AppState.details-w - dx, 200px, 480px);
                        }
                        committed => {
                            AppState.save-layout(AppState.sidebar-w, AppState.details-w, AppState.col-modified-w, AppState.col-kind-w, AppState.col-size-w);
                        }
                    }
                    if AppState.show-details: DetailsPane { width: AppState.details-w; }
                }
            }

            // 状态栏
            Rectangle {
                height: 34px;
                background: Theme.shell.with-alpha(Theme.panel-alpha);
                Rectangle { y: 0; height: 1px; background: Theme.border; }
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 10px;
                    spacing: 8px;
                    Text {
                        text: AppState.status-text;
                        font-size: Theme.fs-small;
                        color: Theme.muted;
                        vertical-alignment: center;
                    }
                    Rectangle { }
                    // 设置按钮（右下角，点击打开"设置"标签页）
                    settings-btn := Rectangle {
                        y: (parent.height - 24px) / 2;
                        height: 24px;
                        border-radius: 6px;
                        background: sb.has-hover ? Theme.primary-soft : transparent;
                        HorizontalLayout {
                            padding-left: 9px;
                            padding-right: 9px;
                            spacing: 5px;
                            Text {
                                text: "\u{E713}";
                                font-family: "Segoe MDL2 Assets";
                                font-size: 13px;
                                color: Theme.primary;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "设置";
                                font-size: Theme.fs-small;
                                color: AppState.active-view == "settings" ? Theme.primary : Theme.muted;
                                font-weight: AppState.active-view == "settings" ? 700 : 400;
                                vertical-alignment: center;
                            }
                        }
                        sb := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { AppState.open-settings-tab(); }
                        }
                    }
                }
            }
        }
    }
    }

    // 浮层：属性对话框
    props := PropertiesDialog {
        width: 100%;
        height: 100%;
        // 关闭时把键盘焦点还给全局快捷键作用域：
        // 校验输入框 LineEdit 打开期间会夺走焦点，关闭后需主动归还，否则全局快捷键失效
        changed open => { if (!self.open) { key-scope.focus(); } }
    }

    // 浮层：空格键 Quick Look 预览
    QuickLook {
        width: 100%;
        height: 100%;
    }

    // 浮层：命令面板
    cmd-palette := CommandPalette {
        open <=> AppState.command-palette-open;
        commands: AppState.palette-commands;
        selected-index: AppState.palette-selected;
        query-changed(t) => { AppState.palette-query(t); }
        execute-command(action) => { AppState.palette-run(action); }
    }

    // 浮层：进度卡片（绑定真实后台任务状态）
    progress := ProgressCard {
        show-progress: AppState.task-active;
        operation: AppState.task-operation;
        current-file: AppState.task-current-file;
        target-path: AppState.task-target;
        completed: AppState.task-completed;
        total: AppState.task-total;
        progress: AppState.task-progress;
        speed: AppState.task-speed;
        eta: AppState.task-eta;
        paused: AppState.task-paused;
        pause-clicked => { AppState.task-pause(); }
        cancel-clicked => { AppState.task-cancel(); }
    }

    // 浮层：同名冲突解决对话框（复制 / 移动遇到目标已存在同名项）
    ConflictDialog {
        width: 100%;
        height: 100%;
        open: AppState.conflict-open;
        name: AppState.conflict-name;
        operation: AppState.conflict-operation;
        src-info: AppState.conflict-src-info;
        dst-info: AppState.conflict-dst-info;
        is-dir: AppState.conflict-is-dir;
        apply-all <=> AppState.conflict-apply-all;
        choose(decision, apply-all) => { AppState.conflict-choose(decision, apply-all); }
    }

    // 浮层：添加网络位置对话框（SMB 挂载）
    NetworkLocationDialog {
        width: 100%;
        height: 100%;
    }

    // 浮层：自定义右键上下文菜单（单面板网格/列表视图；双面板与此电脑视图仍用系统菜单）
    ctxmenu := ContextMenu {
        width: 100%;
        height: 100%;
        // 重命名按活动面板路由：右面板活动时进入右面板行内编辑
        rename-requested(i) => {
            if (AppState.dual-pane && AppState.active-pane == "right") {
                AppState.r-editing-index = i;
            } else {
                AppState.editing-index = i;
            }
        }
    }

    // 由 Rust 调用以进入/退出行内重命名（统一委托给 AppState.editing-index / r-editing-index）
    public function set-editing(idx: int) {
        AppState.editing-index = idx;
    }
    public function set-editing-right(idx: int) {
        AppState.r-editing-index = idx;
    }
    public function clear-editing() {
        AppState.editing-index = -1;
        AppState.r-editing-index = -1;
    }
}
